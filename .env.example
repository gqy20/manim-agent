# в”Җв”Җ Manim Agent зҺҜеўғеҸҳйҮҸй…ҚзҪ®жЁЎжқҝ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# еӨҚеҲ¶жӯӨж–Үд»¶дёә .env е№¶еЎ«е…Ҙе®һйҷ…еҖјпјҡcp .env.example .env

# в”Җв”Җ Database (Neon PostgreSQL)пјҲеҝ…еЎ«пјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# иҺ·еҸ–ж–№ејҸ: neon connection-string

# в”Җв”Җ MiniMax TTSпјҲеҝ…еЎ«пјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
MINIMAX_API_KEY=your-minimax-api-key-here
# MINIMAX_API_BASE_URL=https://api.minimaxi.com          # й»ҳи®ӨеҖјпјҢеӣҪеҶ…еҸҜж”№з”Ё https://api-bj.minimaxi.com

# в”Җв”Җ Claude Agent SDKпјҲеҸҜйҖүпјҢSDK еҶ…йғЁиҮӘеҠЁиҜ»еҸ–пјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# ANTHROPIC_API_KEY=sk-ant-...                              # SDK й»ҳи®Өд»Һ ~/.claude/ иҜ»еҸ–
# ANTHROPIC_MODEL=claude-sonnet-4-6                         # й»ҳи®ӨжЁЎеһӢ
# ANTHROPIC_BASE_URL=https://api.anthropic.com              # API ең°еқҖ

# в”Җв”Җ LoggingпјҲеҸҜйҖүпјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
LOG_LEVEL=INFO                                              # DEBUG / INFO / WARNING / ERROR

# в”Җв”Җ Cloudflare R2 StorageпјҲеҸҜйҖүпјҢдёҚй…ҚзҪ®еҲҷдҪҝз”Ёжң¬ең°ж–Үд»¶зі»з»ҹпјүв”Җв”Җв”Җв”Җ
# иҺ·еҸ–ж–№ејҸ: Cloudflare Dashboard вҶ’ R2 вҶ’ Create API Token
# R2_BUCKET_NAME=manim-agent-videos                     # еӯҳеӮЁжЎ¶еҗҚз§°
# R2_ACCOUNT_ID=your-cloudflare-account-id             # Cloudflare иҙҰжҲ· ID
# R2_ACCESS_KEY_ID=your-r2-access-key-id               # API Token Access Key ID
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key           # API Token Secret Access Key
# R2_PUBLIC_URL=https://cdn.yourdomain.com            # е…¬ејҖи®ҝй—® URLпјҲеҸҜйҖүпјҢз”ЁдәҺиҮӘе®ҡд№үеҹҹеҗҚ/CDNпјү
#                                                         # дёҚи®ҫзҪ®еҲҷдҪҝз”Ё R2 й»ҳи®Өе…¬ејҖең°еқҖ
KEEP_LOCAL_MP4_TASKS=20                                # R2 ДЈКҪПВұЈБфұҫөШ final.mp4 өДИООсКэЈЁУГУЪұҫөШәЛ¶ФЈ©
