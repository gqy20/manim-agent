# ── Manim Agent 环境变量配置模板 ──────────────────────────────
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ── Database (Neon PostgreSQL)（必填）────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# 获取方式: neon connection-string

# ── MiniMax TTS（必填）────────────────────────────────────────
MINIMAX_API_KEY=your-minimax-api-key-here
# MINIMAX_API_BASE_URL=https://api.minimaxi.com          # 默认值，国内可改用 https://api-bj.minimaxi.com

# ── Claude Agent SDK（可选，SDK 内部自动读取）──────────────────
# ANTHROPIC_API_KEY=sk-ant-...                              # SDK 默认从 ~/.claude/ 读取
# ANTHROPIC_MODEL=claude-sonnet-4-6                         # 默认模型
# ANTHROPIC_BASE_URL=https://api.anthropic.com              # API 地址

# ── Logging（可选）───────────────────────────────────────────
LOG_LEVEL=INFO                                              # DEBUG / INFO / WARNING / ERROR

# ── Cloudflare R2 Storage（可选，不配置则使用本地文件系统）────
# 获取方式: Cloudflare Dashboard → R2 → Create API Token
# R2_BUCKET_NAME=manim-agent-videos                     # 存储桶名称
# R2_ACCOUNT_ID=your-cloudflare-account-id             # Cloudflare 账户 ID
# R2_ACCESS_KEY_ID=your-r2-access-key-id               # API Token Access Key ID
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key           # API Token Secret Access Key
# R2_PUBLIC_URL=https://cdn.yourdomain.com            # 公开访问 URL（可选，用于自定义域名/CDN）
#                                                         # 不设置则使用 R2 默认公开地址
